{
  "description": "SF Compound Engineering plugin hooks for Salesforce development workflow",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Salesforce CLI command detected'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File written - consider running /sf-review'"
          }
        ]
      }
    ]
  }
}
